# ----------------------------------------------------------------------------
# Wiim Dashboard — environment
# Copy to .env and fill in. NEVER commit the real .env.
# ----------------------------------------------------------------------------

# Public origin the app is served from (used for strict CSRF origin checks and
# secure-cookie behaviour). Set to your Zoraxy-fronted https URL in production.
APP_ORIGIN=https://wiim.example.com

# 32+ byte random secret. Generate with: openssl rand -base64 48
# Used to sign session/CSRF artifacts. Changing it invalidates all sessions.
AUTH_SECRET=change-me-openssl-rand-base64-48

# Where the SQLite database + runtime data live (mounted as a Docker volume).
DATA_DIR=/data

# The app runs behind Zoraxy (a trusted reverse proxy), so honour
# X-Forwarded-For / X-Forwarded-Proto for client IP + https detection.
TRUST_PROXY=true

# Listen port (Zoraxy points here).
PORT=3000

# Session cookies are Secure (https-only) by default in production. Set to
# false ONLY when testing over plain http on a LAN IP. Behind https, leave unset.
# COOKIE_SECURE=false

# --- Cloudflare Turnstile (bot protection on login) -------------------------
# You can also set these later in Settings. If left blank, Turnstile is
# disabled until configured (login still requires a password).
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# --- WiiM device TLS (optional) ---------------------------------------------
# Most WiiM units accept plain TLS with verification disabled (the default).
# A few newer firmwares require the LinkPlay mutual-TLS client certificate.
# If a device refuses the TLS handshake, drop the PEMs here and set the paths.
# WIIM_CLIENT_CERT_PATH=/data/linkplay-client.crt
# WIIM_CLIENT_KEY_PATH=/data/linkplay-client.key

# --- WiiM device tuning (optional) ------------------------------------------
# Max concurrent httpapi requests sent to ONE device at a time. The embedded
# LinkPlay box can drop/garble requests under a parallel burst (a single
# snapshot poll fans out ~9 reads). Default 4; lower to 1–2 for older / flaky
# devices, raise for fast units on a quiet network.
# WIIM_DEVICE_CONCURRENCY=4

# Album-art fallback: when a track (often a local/NAS file) exposes no embedded
# cover art, look one up by artist + album via the iTunes Search API (keyless).
# On by default; set to false/0/off to disable all external artwork lookups.
# WIIM_ARTWORK_FALLBACK=true
